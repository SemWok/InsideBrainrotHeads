-- [ FUNCTIONS ]
local function KillCharacter()
    if LP.Character and LP.Character:FindFirstChild("Humanoid") then
        task.wait(0.1)
        LP.Character.Humanoid.Health = 0
    end
end

local function DoBaseTeleport()
    if savedPos and LP.Character:FindFirstChild("HumanoidRootPart") then
        LP.Character.HumanoidRootPart.CFrame = savedPos
        task.spawn(KillCharacter)
    end
end

local function SpawnMiniTPMenu()
    if PlayerGui:FindFirstChild("SemWokMiniMenu") then return end
    local MiniSG = Instance.new("ScreenGui", PlayerGui)
    MiniSG.Name = "SemWokMiniMenu"
    local F = Instance.new("Frame", MiniSG)
    F.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    F.Position = UDim2.new(0.45, 0, 0.45, 0)
    F.Size = UDim2.new(0, 120, 0, 50)
    F.Active = true; F.Draggable = true
    
    local SetB = Instance.new("TextButton", F)
    SetB.Size = UDim2.new(0, 50, 0, 30); SetB.Position = UDim2.new(0, 5, 0, 10)
    SetB.Text = "Set"; SetB.BackgroundColor3 = Color3.fromRGB(150, 0, 0); SetB.TextColor3 = Color3.new(1,1,1)
    
    local TPB = Instance.new("TextButton", F)
    TPB.Size = UDim2.new(0, 50, 0, 30); TPB.Position = UDim2.new(0, 65, 0, 10)
    TPB.Text = "TP"; TPB.BackgroundColor3 = Color3.fromRGB(150, 0, 0); TPB.TextColor3 = Color3.new(1,1,1)

    SetB.MouseButton1Click:Connect(function() 
        savedPos = LP.Character.HumanoidRootPart.CFrame 
        SetB.Text = "Saved!"; task.wait(0.5); SetB.Text = "Set"
    end)
    TPB.MouseButton1Click:Connect(DoBaseTeleport)
end

-- [ UI BUILDER ]
local function CreateFrame(name, pos, size, titleTxt)
    local f = Instance.new("Frame", SG)
    f.Name = name; f.BackgroundColor3 = Color3.fromRGB(20, 20, 20); f.Position = pos; f.Size = size
    f.Active = true; f.Draggable = true; f.ClipsDescendants = false
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 8)
    
    local title = Instance.new("TextLabel", f)
    title.Size = UDim2.new(1, 0, 0, 40); title.Position = UDim2.new(0, 0, 0, 0)
    title.Text = titleTxt; title.TextColor3 = Color3.new(1, 1, 1)
    -- JUDUL DI PERBESAR KE 18 DAN BOLD
    title.Font = Enum.Font.SourceSansBold; title.TextSize = 18; title.BackgroundTransparency = 1
    
    local ytClosed = Instance.new("TextLabel", f)
    ytClosed.Name = "WatermarkClosed"
    ytClosed.Size = UDim2.new(1, 0, 0, 40); ytClosed.Position = UDim2.new(0, 0, 0, 0)
    ytClosed.Text = "YOUTUBE: SEMWOK"; ytClosed.TextColor3 = Color3.new(1, 1, 1)
    ytClosed.Font = Enum.Font.SourceSansBold; ytClosed.TextSize = 15; ytClosed.BackgroundTransparency = 1; ytClosed.Visible = false
    
    local toggleBtn = Instance.new("TextButton", f)
    toggleBtn.Size = UDim2.new(0, 30, 0, 30); toggleBtn.Position = UDim2.new(1, -35, 0, 5)
    toggleBtn.Text = "▼"; toggleBtn.TextColor3 = Color3.new(1, 1, 1)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    toggleBtn.BorderSizePixel = 0
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 4)
    
    local content = Instance.new("Frame", f)
    content.Name = "Content"
    content.Size = UDim2.new(1, 0, 1, -80); content.Position = UDim2.new(0, 0, 0, 45)
    content.BackgroundTransparency = 1; content.ClipsDescendants = true
    
    local ytInside = Instance.new("TextLabel", f)
    ytInside.Size = UDim2.new(1, 0, 0, 40)
    ytInside.AnchorPoint = Vector2.new(0.5, 1)
    ytInside.Position = UDim2.new(0.5, 0, 1, 0)
    ytInside.Text = "YOUTUBE: SEMWOK"
    ytInside.TextColor3 = Color3.fromRGB(255, 255, 255)
    ytInside.Font = Enum.Font.SourceSansBold; ytInside.TextSize = 15
    ytInside.BackgroundTransparency = 1
    ytInside.TextXAlignment = Enum.TextXAlignment.Center
    ytInside.TextYAlignment = Enum.TextYAlignment.Center

    local isOpen = true
    toggleBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        f:TweenSize(isOpen and size or UDim2.new(0, size.X.Offset, 0, 40), "Out", "Quad", 0.2)
        toggleBtn.Text = isOpen and "▼" or "▲"
        content.Visible = isOpen
        title.Visible = isOpen 
        ytClosed.Visible = not isOpen
        ytInside.Visible = isOpen
    end)
    return content
end

local function AddBtn(parent, txt, callback)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(0.92, 0, 0, 35)
    b.Position = UDim2.new(0.04, 0, 0, (#parent:GetChildren()-1)*40)
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 40); b.Text = txt; b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.SourceSansBold; b.TextSize = 14
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
    b.MouseButton1Click:Connect(callback)
end

